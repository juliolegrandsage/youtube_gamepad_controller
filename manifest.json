{
  "manifest_version": 3,
  "name": "Youtube Gamepad",
  "version": "1.1",

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
  "16": "logo16.png",
  "48": "logo48.png",
  "128": "logo128.png"
}
}