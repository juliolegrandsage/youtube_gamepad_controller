{
  "manifest_version": 3,
  "name": "Youtube Gamepad",
  "version": "1.1",

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["keyboard.js", "content.js"],
      "css": ["keyboard.css"]
    }
  ],
  "icons": {
  "16": "logo16.png",
  "48": "logo48.png",
  "128": "logo128.png"
},
"web_accessible_resources": [
  {
    "resources": [
      "keyboard.html",
      "connectedAlert.css",
      "connected.html"
    ],
    "matches": ["https://*.youtube.com/*"]
  }
]
}